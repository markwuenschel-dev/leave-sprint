{
  "name": "leave-sprint-twin",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo: Waypoint (career hub) + Leave Sprint Twin (frozen). Local-first.",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "pnpm --filter waypoint dev",
    "build": "pnpm --filter waypoint build",
    "start": "pnpm --filter waypoint start",
    "db:migrate": "pnpm --filter waypoint db:migrate",
    "dev:twin": "next dev --turbopack --port 3001",
    "build:twin": "next build",
    "start:twin": "pnpm db:migrate:twin && next start --port 3001",
    "db:migrate:twin": "tsx lib/db/migrate.ts",
    "db:generate:twin": "drizzle-kit generate",
    "lint": "oxlint apps/waypoint packages",
    "lint:fix": "oxlint apps/waypoint packages --fix"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@tailwindcss/postcss": "^4.3.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.12.0",
    "lucide-react": "^0.525.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.23.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.73.0",
    "postcss": "^8.5",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1",
    "typescript": "^6.0.3"
  }
}
