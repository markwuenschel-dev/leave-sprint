{
  "name": "leave-sprint-twin",
  "version": "0.1.0",
  "private": true,
  "description": "Leave Sprint Twin — Next.js dashboard for the 29-day leave sprint (June 17 – July 15 2026), Postgres-backed, token-gated.",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "pnpm db:migrate && next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@tailwindcss/postcss": "^4.3.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.12.0",
    "lucide-react": "^0.525.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tsx": "^4.23.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1",
    "typescript": "^6.0.3"
  }
}
