# Copy to apps/waypoint/.env.local (gitignored). Next loads .env.local for THIS app —
# the repo-root .env is not loaded for apps/waypoint.
#
# AI Interviewer provider keys. Set at least one — a provider is "available" in the
# AI Mock tab iff its key is present. Restart the dev server after adding keys.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=
