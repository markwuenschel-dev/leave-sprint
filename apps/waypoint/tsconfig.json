{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@waypoint/rubric": ["../../packages/rubric/src/index.ts"],
      "@waypoint/qbank": ["../../packages/qbank/src/index.ts"],
      "@waypoint/practice-types": ["../../packages/practice-types/src/index.ts"]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
