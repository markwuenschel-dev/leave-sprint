{
  "name": "waypoint",
  "version": "0.1.0",
  "private": true,
  "description": "Waypoint — personal career transition hub (local-first)",
  "scripts": {
    "dev": "next dev --turbopack --port 3210 --hostname 0.0.0.0",
    "build": "next build",
    "start": "pnpm db:migrate && next start --hostname 0.0.0.0",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@electric-sql/pglite": "^0.5.4",
    "@google/genai": "^2.10.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@waypoint/practice-types": "workspace:*",
    "@waypoint/qbank": "workspace:*",
    "@waypoint/rubric": "workspace:*",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.12.0",
    "lucide-react": "^0.525.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.2.0",
    "tsx": "^4.23.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5",
    "tailwindcss": "^4.1",
    "typescript": "^6.0.3"
  }
}
