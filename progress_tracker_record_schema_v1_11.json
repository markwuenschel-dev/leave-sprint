    {
      "if": {
        "properties": {
          "taskType": {
            "const": "coding"
          }
        }
      },
      "then": {
        "required": [
          "problemName"
        ],
        "properties": {
          "problemName": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attemptType": {
            "enum": [
              "retry",
              "assisted_retry",
              "post_coaching_retry",
              "final_retry",
              "retention_retest"
            ]
          }
        },
        "required": [
          "attemptType"
        ]
      },
      "then": {
        "required": [
          "attemptGroupId",
          "attemptNumber"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "coverageStatus": {
            "const": "included"
          },
          "attemptType": {
            "not": {
              "enum": [
                "session_parent",
                "rollup"
              ]
            }
          }
        },
        "required": [
          "coverageStatus",
          "attemptType"
        ]
      },
      "then": {
        "required": [
          "assessmentOutcome"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "assessmentOutcome": {
            "enum": [
              "Partial discovery",
              "Concept discovery"
            ]
          }
        },
        "required": [
          "assessmentOutcome"
        ]
      },
      "then": {
        "required": [
          "conceptDiscovery"
        ]
      }
    }
  ]
