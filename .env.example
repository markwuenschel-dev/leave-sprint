# Copy to .env.local for local dev, or set these in the Railway service.

# Postgres connection. When UNSET, the app uses an embedded PGlite database at
# ./.pglite (zero-setup local dev). Railway's Postgres plugin provides this.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Shared access token that gates the whole site. When UNSET, the app is open
# (fine for local dev). Set a strong value in Railway.
# APP_TOKEN=change-me
