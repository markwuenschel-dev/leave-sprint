# Copy to .env (repo root) for local dev — this single file is the source of truth.
# apps/waypoint loads it via next.config.ts (Next otherwise only reads app-folder
# env files). .env is gitignored.

# Postgres connection. When UNSET, the app uses an embedded PGlite database at
# ./.pglite (zero-setup local dev).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Shared access token that gates the whole site. When UNSET, the app is open
# (fine for local dev). Set a strong value in production.
# APP_TOKEN=change-me

# -----------------------------------------------------------------------------
# LLM: preferred path = local LiteLLM gateway (see litellm-langfuse-gateway repo)
# When LITELLM_VIRTUAL_KEY is set (must start with sk-), AI Interviewer routes
# all providers through the gateway. You do NOT need provider keys in this app.
# Gateway must be running (Docker). Restart `pnpm dev` after changing these.
# -----------------------------------------------------------------------------
LITELLM_BASE_URL=http://localhost:4000/v1
# From: uv run llg keys create --models llm-general,openai-general,anthropic-general,gemini-general,grok-general \
#   --max-budget 50 --rpm 120 --key-alias leave-sprint-dev
LITELLM_VIRTUAL_KEY=
# Call origin in Langfuse (gateway adapters always send metadata when this is set)
SERVICE_NAME=leave-sprint
# ENVIRONMENT=development
# Hermetic/test: set LLG_HERMETIC=1 (or NODE_ENV=test) to refuse all live LLM calls.
# Opt-in paid runs only: LLG_ALLOW_LIVE=1
# Optional: force one gateway alias for every provider (default: per-provider *-general)
# LITELLM_MODEL=llm-general

# Direct provider keys (legacy / fallback when LITELLM_VIRTUAL_KEY is unset).
# A provider is "available" iff its key is set OR the gateway virtual key is set.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=

# Dictation (voice) still uses OpenAI Whisper and needs OPENAI_API_KEY unless you
# add a gateway audio route later.
# OPENAI_API_KEY=
